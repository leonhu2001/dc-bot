[Unit]
Description=DC Bot Web Dashboard
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/dc-bot
EnvironmentFile=/opt/dc-bot/web/.env
ExecStart=/opt/dc-bot/venv/bin/python -m uvicorn web.app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
